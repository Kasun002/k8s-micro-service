{
  "name": "message-queue",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:services": "eslint 'cart-service/src/**/*.ts' 'purchase-service/src/**/*.ts' 'product-service/src/**/*.ts'",
    "lint:frontend": "yarn --cwd frontend next lint",
    "lint:fix": "eslint --fix 'cart-service/src/**/*.ts' 'purchase-service/src/**/*.ts' 'product-service/src/**/*.ts'",
    "format": "prettier --write '**/*.{ts,tsx,js,mjs,json,md}' --ignore-path .gitignore"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
